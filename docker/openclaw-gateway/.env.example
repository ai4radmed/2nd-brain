# 2nd-brain OpenClaw 게이트웨이 환경변수 — 이 파일을 .env 로 복사해 채운다.
# ⚠️ .env 는 secret 포함 → git 미추적 (repo .gitignore 가 차단). 이 .example 만 추적.

# 이미지·포트·기본
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789      # 호스트 publish 포트 (운영=18789, 데모 2번째=18889 등)
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=Asia/Seoul

# 경로 override (기본값은 compose 의 ${HOME} 기준 — 보통 그대로 둔다)
#   Claude 자격증명 기본 = $HOME/.openclaw/.claude (게이트웨이 onboarding 이 거기 생성/마운트).
# OPENCLAW_CLAUDE_DIR=$HOME/.openclaw/.claude
# OPENCLAW_CONFIG_DIR=$HOME/.openclaw
# GOGCLI_DIR=$HOME/.config/gogcli-openclaw-container
# VAULT_DIR=$HOME/projects/2nd-brain-vault      # 데모면 $HOME/projects/2nd-brain-vault-demo

# secret / 계정 — 자기 값으로 채움 (절대 commit 금지)
GOG_KEYRING_PASSWORD=<gog 컨테이너 키링 비번>
GMAIL_ROUTER_ACCOUNT=<your@gmail.com>
GMAIL_ROUTER_INBOX=/home/node/projects/2nd-brain-vault/sources/00_inbox
# OPENCLAW_GATEWAY_TOKEN=     # 보통 onboarding 이 자동 발급
