# Copy to .env and customize.
# Verify host UID/GID with: id -u; id -g

UID=1000
GID=1000

# Pin the claude binary version bundled into the openclaw-gateway image.
# OpenClaw's claude-cli/* legacy refs invoke `claude` as a subprocess (the
# Pro/Max OAuth path); the image bakes this version via Claude's native
# installer (DISABLE_AUTOUPDATER=1). Keep it matched to the host native
# Claude Code (`make sync`) or bump manually + `make build-openclaw`.
CLAUDE_CODE_VERSION=2.1.128

# Host paths (override only if non-default).
# Container always mounts to /home/user/projects/2nd-brain-vault{,-guide} (do not change).
# SB_DATA=${HOME}/projects/2nd-brain-vault
# SB_GUIDE=${HOME}/projects/2nd-brain-vault-guide

# brain-pdf service version (Docling + MinerU PDF parser).
# `make build-brain-pdf` / `run-brain-pdf` 등이 이 값을 이미지 태그로 사용.
# 머신-agnostic — scripts/detect-compose.sh 가 NVIDIA 환경 자동 감지해 GPU/CPU 변형
# 둘 다 같은 태그로 동작 (cu126 wheel 이 PyTorch runtime adapter 통해 양쪽 작동).
# Bump 시점: Dockerfile / requirements.txt / entrypoint.py 변경 시.
BRAIN_PDF_VERSION=2026.05.14
