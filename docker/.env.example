# Copy to .env and customize.
# Verify host UID/GID with: id -u; id -g

UID=1000
GID=1000

# Host paths (override only if non-default).
# Container always mounts to /home/user/projects/2nd-brain-vault{,-guide} (do not change).
# SB_DATA=${HOME}/projects/2nd-brain-vault
# SB_GUIDE=${HOME}/projects/2nd-brain-vault-guide

# 2nd-brain-parser 이미지 (Docling + MinerU 문서 파서, ghcr pull).
# compose 의 ${PARSER_IMAGE:-<digest>} 가 이 값을 이미지 참조로 사용 (override 시에만 설정).
# 기본값 = 검증된 brain-pdf 빌드를 digest 로 핀(불변). 이동하는 :latest 가 CLI 리네임
#   (2nd-brain-parser→brain-pdf)으로 parser-drain 을 깨뜨린 사례(2026-06-22) 재발 방지.
#   새 빌드 채택 시 compose 의 digest + 아래 값을 함께 갱신.
# 머신-agnostic — scripts/detect-compose.sh 가 NVIDIA 환경 자동 감지해 GPU/CPU 변형
# 둘 다 같은 이미지로 동작 (cu126 wheel 이 PyTorch runtime adapter 통해 양쪽 작동).
# 태그로 풀려면: PARSER_IMAGE=ghcr.io/benkorea/2nd-brain-parser:<태그>
# 발행 절차: docs/2nd-brain-parser-setup.md 메인테이너 노트.
PARSER_IMAGE=ghcr.io/benkorea/2nd-brain-parser@sha256:488a6620a10e237f2303463dea3769ed67562cb75040d1a73f68d9074f4521d5
